# local.properties — copy this file to local.properties and fill in values.
# DO NOT commit local.properties to source control (it is gitignored by default).

# Full URL of the UI Blueprint backend, e.g. http://192.168.1.100:8000
BACKEND_BASE_URL=http://10.0.2.2:8000

# Bearer token that matches the API_KEY on the backend server.
BACKEND_API_KEY=change-me
